# CONFIG FILE

# FastAPI uvicorn
UVICORN_HOST = 0.0.0.0
UVICORN_PORT = 8080
UVICORN_RELOAD = False

# mosquitto
MQTT_HOST = mosquitto
MQTT_PORT = 1883

# timescaledb
DB_HOST=timescaledb
DB_PORT=5432
DB_NAME=postgres
DB_USER=postgres
DB_PASSWORD=password # set your password of timescaledb
DB_LOCATION=<your-path> # set system path to your local db. examples: /home/user/postgres or C:/postgres

# SUPERSET
SUPERSET_PORT=8088
SUPERSET_KEY=superset_key # set your superset secret key
SUPERSET_ADMIN_USERNAME=admin #set your admin username
SUPERSET_ADMIN_FIRSTNAME=admin #set your admin firstname
SUPERSET_ADMIN_LASTNAME=superset #set your admin lastname
SUPERSET_ADMIN_PASSWORD=admin # set your admin password of superset
SUPERSET_ADMIN_EMAIL=adm@adm.adm # set your admin email of superset

# DB FOR SUPERSET
SUPERSET_DB_HOST=superset_db
SUPERSET_DB_PORT=5432
SUPERSET_DB_NAME=superset
SUPERSET_DB_USER=superset
SUPERSET_DB_PASSWORD=superset